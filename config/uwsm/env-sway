# Sway-specific session environment (sourced by uwsm for sway sessions only).
# Changes require a logout/login to take effect.

profile="env-sway-laptop"
if [[ "${HOSTNAME:-}" == "desktop" ]]; then
  profile="env-sway-desktop"
fi

# shellcheck disable=SC1090
source "${XDG_CONFIG_HOME:-$HOME/.config}/uwsm/$profile"
