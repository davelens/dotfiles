### Input #####################################################################

input type:touchpad {
  dwt enabled
  tap enabled
  natural_scroll disabled
  middle_emulation enabled
}

input type:pointer {
  pointer_accel -0.5
}

# Disable Caps Lock entirely. kanata remaps `caps` to escape/ctrl, leaving no
# key that can emit a real Caps Lock, so a stray toggle would otherwise get
# stuck on with no way to turn it off.
# Read `man 5 sway-input` for more info.
input type:keyboard {
  xkb_options caps:none
}
