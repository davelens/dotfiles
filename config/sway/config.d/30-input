### Input #####################################################################

input type:touchpad {
  dwt enabled
  tap enabled
  natural_scroll disabled
  middle_emulation enabled
}

input type:pointer {
  pointer_accel -0.5
}

# To configure keyboard layouts e.a.
# Read `man 5 sway-input` for more info.
#
#   input type:keyboard {
#       xkb_layout "eu"
#   }
