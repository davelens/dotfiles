# Ghostty configuration
# Mirrors the wezterm config at config/wezterm/wezterm.lua

font-family = Hack Nerd Font
font-size = 14

# We use 12% in ghostty; the 8% scaling I have on wezterm produces artifacting
# in ghostty.
adjust-cell-height = 12%

theme = Catppuccin Mocha

window-padding-x = 10
window-padding-y = 0
confirm-close-surface = false
gtk-titlebar = false

copy-on-select = clipboard

cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor
