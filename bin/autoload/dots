#!/usr/bin/env bash
# shellcheck disable=SC2154,SC1091
set -eo pipefail

# TODO: Change the `dots` command to git init DOTFILES_REPO_HOME, if necessary.

source "$DOTFILES_CONFIG_HOME"/env

log_file="$DOTFILES_STATE_HOME"/dots.log
[ ! -f "$log_file" ] && touch "$log_file"

usage() {
  echo
  echo "Usage: $(basename "$0") [-h|--help] <command>"
  echo
  echo "Commands:"
  echo "  logs         Opens the logfile in $EDITOR (read-only if applicable)."
  echo "  install      Attempts a (re)install through dotbot."
  echo "  update       Updates dotbot and all local dot-repos."
  echo "  setup        Sets up additional dotfile repositories."
  echo "               Use --arch to setup dotsys (arch), dotvim, and dotshell."
  echo "               Use --dotsys <arch|macos|wsl> to setup davelens/dotsys."
  echo "               Use --dotshell to setup davelens/dotshell."
  echo "               Use --dotvim to setup davelens/dotvim."
  echo
  echo "Options:"
  echo "  -h|--help    Show this help message and exit."
  exit
}

logs() {
  if [ ! -s "$log_file" ]; then
    fail "$($print_status -i error "The log file is currently empty.")"
  fi

  if [[ "$EDITOR" == *vim* ]]; then
    winbar='Press "q" to stop reading or "c" to clear the logs'

    $EDITOR \
      -c 'set nomodifiable laststatus=0' \
      -c 'highlight WinBarMsg guifg=#ffcc00 guibg=#44475a gui=bold' \
      -c "lua vim.o.winbar = '%#WinBarMsg#$winbar'" \
      -c 'nnoremap q :q<CR>' \
      -c "nnoremap c :silent !truncate -s 0 '$log_file' \| edit<CR>" \
      -R + "$log_file"
  else
    $EDITOR "$log_file"
  fi
}

install() {
  "$DOTFILES_REPO_HOME/setup/install"
}

update_dotbot() {
  $print_status -nc "Updating dotbot to latest master ..."

  local dotbot_path="$DOTFILES_REPO_HOME/dotbot"

  if git -C "$dotbot_path" fetch origin >/dev/null 2>&1 &&
    git -C "$dotbot_path" checkout origin/master >/dev/null 2>&1; then
    if git -C "$DOTFILES_REPO_HOME" diff --quiet dotbot; then
      $print_status -i ok "dotbot already up to date"
    else
      git -C "$DOTFILES_REPO_HOME" add dotbot
      git -C "$DOTFILES_REPO_HOME" commit -m "Update dotbot submodule to latest master" &>>"$log_file"
      $print_status -i ok "dotbot updated and committed"
    fi
  else
    $print_status -i error "Failed to update dotbot"
    return 1
  fi
}

update_repo() {
  local repo_path="$1"
  local repo_name
  repo_name=$(basename "$repo_path")

  $print_status -nc "Updating $repo_name ..."

  # Check for uncommitted changes (unstaged and staged)
  if ! git -C "$repo_path" diff-files --quiet 2>/dev/null ||
    ! git -C "$repo_path" diff-index --cached --quiet HEAD 2>/dev/null; then
    $print_status -i error "$repo_name has uncommitted changes, skipping"
    return 1
  fi

  if ! git -C "$repo_path" pull --rebase &>>"$log_file"; then
    $print_status -i error "Failed to update $repo_name"
    return 1
  fi

  $print_status -i ok "$repo_name updated"
}

run_with_headers() {
  while IFS= read -r line; do
    echo "$line" >>"$log_file"
    if [[ "$line" == *"==>"* ]]; then
      $print_status -i pending "${line##*==> }"
    fi
  done
}

setup() {
  local dotsys=""
  local dotshell=0
  local dotvim=0

  # Parse flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --arch)
      dotsys="arch"
      dotvim=1
      dotshell=1
      shift
      ;;
    --dotsys)
      shift
      if [[ $# -eq 0 ]]; then
        $print_status -i error "--dotsys requires a value (arch, macos, or wsl)"
        exit 1
      fi

      case "$1" in
      arch | macos | wsl)
        dotsys="$1"
        ;;
      *)
        $print_status -i error "Invalid dotsys value: $1 (must be arch, macos, or wsl)"
        exit 1
        ;;
      esac
      shift
      ;;
    --dotshell)
      dotshell=1
      shift
      ;;
    --dotvim)
      dotvim=1
      shift
      ;;
    *)
      $print_status -i error "Unknown option: $1"
      exit 1
      ;;
    esac
  done

  if [[ -z "$dotsys" && $dotshell -eq 0 && $dotvim -eq 0 ]]; then
    $print_status -i error "At least one of --dotsys, --dotshell, or --dotvim is required"
    exit 1
  fi

  local error_occurred=0

  # Setup dotsys configs if requested
  if [[ -n "$dotsys" ]]; then
    local dotsys_path="$REPO_NAMESPACE/davelens/dotsys"

    $print_status -nc "Cloning dotsys repository ..."

    if [[ -d "$dotsys_path" ]]; then
      $print_status -i ok "dotsys already exists at $dotsys_path"
    else
      mkdir -p "$(dirname "$dotsys_path")"
      if git clone https://github.com/davelens/dotsys.git "$dotsys_path" &>>"$log_file"; then
        $print_status -i ok "dotsys cloned successfully"
      else
        $print_status -i error "Failed to clone dotsys"
        error_occurred=1
      fi
    fi

    if [[ $error_occurred -eq 0 ]]; then
      $print_status -nc "Running $dotsys init script ..."
      if "$dotsys_path/$dotsys/init.sh" 2>&1 | run_with_headers; then
        $print_status -i ok "$dotsys setup complete"
      else
        $print_status -i error "$dotsys setup failed"
        error_occurred=1
      fi
    fi
  fi

  # Setup dotshell configs if requested
  if [[ $dotshell -eq 1 ]]; then
    local dotshell_path="$REPO_NAMESPACE/davelens/dotshell"

    $print_status -nc "Cloning dotshell repository ..."

    if [[ -d "$dotshell_path" ]]; then
      $print_status -i ok "dotshell already exists at $dotshell_path"
    else
      mkdir -p "$(dirname "$dotshell_path")"
      if git clone https://github.com/davelens/dotshell.git "$dotshell_path" &>>"$log_file"; then
        $print_status -i ok "dotshell cloned successfully"
      else
        $print_status -i error "Failed to clone dotshell"
        error_occurred=1
      fi
    fi

    if [[ $error_occurred -eq 0 ]]; then
      $print_status -nc "Running dotshell init script ..."
      if "$dotshell_path/setup/init.sh" 2>&1 | run_with_headers; then
        $print_status -i ok "dotshell setup complete"
      else
        $print_status -i error "dotshell setup failed"
        error_occurred=1
      fi
    fi
  fi

  # Setup dotvim configs if requested
  if [[ $dotvim -eq 1 ]]; then
    local dotvim_path="$REPO_NAMESPACE/davelens/dotvim"

    $print_status -nc "Cloning dotvim repository ..."

    if [[ -d "$dotvim_path" ]]; then
      $print_status -i ok "dotvim already exists at $dotvim_path"
    else
      mkdir -p "$(dirname "$dotvim_path")"
      if git clone https://github.com/davelens/dotvim.git "$dotvim_path" &>>"$log_file"; then
        $print_status -i ok "dotvim cloned successfully"
      else
        $print_status -i error "Failed to clone dotvim"
        error_occurred=1
      fi
    fi

    if [[ $error_occurred -eq 0 ]]; then
      $print_status -nc "Running dotvim install script ..."
      if "$dotvim_path/setup/install" 2>&1 | tee -a "$log_file"; then
        $print_status -i ok "dotvim setup complete"
      else
        $print_status -i error "dotvim setup failed"
        error_occurred=1
      fi
    fi
  fi

  [[ $error_occurred -ne 0 ]] && exit 1
}

update() {
  update_dotbot

  # Update all locally installed dot-repos
  local dotfiles_updated=0
  for repo_path in "$REPO_NAMESPACE"/davelens/dot*; do
    [[ -d "$repo_path/.git" ]] || continue

    if update_repo "$repo_path"; then
      [[ "$repo_path" == "$DOTFILES_REPO_HOME" ]] && dotfiles_updated=1
    fi
  done

  # Run the dotfiles installer after all repos are updated
  if [[ $dotfiles_updated -eq 1 ]]; then
    $print_status -nc "Running dotfiles installer ..."
    if "$DOTFILES_REPO_HOME/setup/install" &>>"$log_file"; then
      $print_status -i ok "dotfiles installer complete"
    else
      $print_status -i error "dotfiles installer failed"
    fi
  fi

  echo
  echo "Logs available at $log_file"
}

###############################################################################

main() {
  [ $# -eq 0 ] && usage

  case "$1" in
  -h | --help)
    usage
    ;;
  logs)
    logs
    ;;
  install)
    install
    ;;
  update)
    update
    ;;
  setup)
    shift
    setup "$@"
    ;;
  *)
    echo "Unknown command: $1"
    usage
    ;;
  esac
}

main "$@"
